# Kalshi Crypto Streak Monitor Environment Variables

# Primary Email Alert Recipient
RECIPIENT_EMAIL=danelujapare@gmail.com

# SMTP Server Credentials (Required for sending actual emails)
# Example for Gmail:
# 1. Enable 2-Step Verification on your Google Account
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Enter SMTP_USERNAME (your gmail) and SMTP_PASSWORD (the 16-character App Password)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SENDER_EMAIL=your-gmail-address@gmail.com

# Discord Webhook URL for alerts (Optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Telegram Bot Token & Chat ID for alerts (Optional)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=-1001234567890

# Polling Interval (in seconds, default 60)
POLL_INTERVAL_SECONDS=60
